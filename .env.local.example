# Copy this file to .env.local and set the values for your local environment.
# The relay requires these four environment variables at runtime:
# - EZPDS_PUBLIC_URL: the relay's public HTTPS URL (must start with https://)
# - EZPDS_AVAILABLE_USER_DOMAINS: comma-separated list of user domain(s)
# - EZPDS_SIGNING_KEY_MASTER_KEY: 64-hex-digit master key (64 chars → 32 bytes)
# - EZPDS_ADMIN_TOKEN: optional; required only for admin endpoints

EZPDS_PUBLIC_URL=https://relay.local
EZPDS_AVAILABLE_USER_DOMAINS=example.com
EZPDS_SIGNING_KEY_MASTER_KEY=2a55ebbdb7c0a4864a3944a443765b13602c6fbbeda38c2d6afc57b96663810e
EZPDS_ADMIN_TOKEN=local-admin-token
