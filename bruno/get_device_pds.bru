meta {
  name: Get Device PDS
  type: http
  seq: 25
}

get {
  url: {{baseUrl}}/v1/devices/{{deviceId}}/pds
  body: none
  auth: bearer
}

auth:bearer {
  token: {{deviceToken}}
}

docs {
  Returns the PDS's connection endpoints for a registered device.

  Response: { pdsUrl, websocketUrl, irohEndpoint? }
  - pdsUrl: the PDS's public HTTPS URL
  - websocketUrl: pdsUrl with the wss:// scheme (firehose/subscriptions)
  - irohEndpoint (optional): the PDS's Iroh QUIC node id, for NAT-traversing
    device->PDS connections. Present only when the Iroh tunnel is enabled
    ([iroh] enabled / EZPDS_IROH_ENABLED=true). It is the live node id of the
    bound endpoint (stable across restarts when the signing-key master key is
    set), unless [iroh] endpoint is set as a manual override. Omitted when the
    tunnel is disabled.

  Requires the device's bearer token (returned once at registration).
}
