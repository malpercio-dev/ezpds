meta {
  name: Reset Password (resetPassword)
  type: http
  seq: 27
}

post {
  url: {{baseUrl}}/xrpc/com.atproto.server.resetPassword
  body: json
  auth: none
}

body:json {
  {
    "token": "{{resetToken}}",
    "password": "newpassword123"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8080
}
