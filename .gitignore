# Rust build artifacts
/target/

# Stray Cargo home caches — the real CARGO_HOME is .devenv/state/cargo (already
# ignored via .devenv/). These root-level dirs appear when cargo runs outside the
# dev shell, or under a sandbox that redirects CARGO_HOME to the repo root. Pure
# regenerable registry cache (see registry/CACHEDIR.TAG), never source.
# Ignore the contents (not the dir itself, so the one tracked file below can be
# re-included) and keep the committed cargo-audit policy.
/.cargo/*
!/.cargo/audit.toml
/.cargo-home-probe/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# Environment files
.env
.env.local
.env.*.local

# pnpm store
.pnpm-store/

# Nix / devenv
.devenv/
.direnv/
devenv.local.nix
/result

# Git worktrees
.worktrees/

# playwright-mcp
.playwright-mcp/

# LLM Wiki (local knowledge store — not source)
.llm-wiki/

# SvelteKit / frontend build artifacts
apps/identity-wallet/.svelte-kit/
apps/identity-wallet/dist/
apps/identity-wallet/node_modules/
apps/identity-wallet/package-lock.json
apps/admin-companion/.svelte-kit/
apps/admin-companion/dist/
apps/admin-companion/node_modules/
apps/admin-companion/package-lock.json

# Tauri-generated Xcode project (machine-specific; regenerated per developer via `cargo tauri ios init`)
apps/identity-wallet/src-tauri/gen/
apps/admin-companion/src-tauri/gen/

# `cargo tauri icon` build output (ios-postinit Patch G renders apps/<app>/app-icon.png
# here; only the iOS set — written into the gitignored gen/apple catalog — is shipped)
apps/identity-wallet/src-tauri/icons-build/
apps/admin-companion/src-tauri/icons-build/
.pi/extensions/*/node_modules/

# Claude Code agent worktrees (session-local, never committed)
.claude/worktrees/
