<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    The operator console's iOS code-signing entitlements. Referenced by the shared
    XcodeGen template (scripts/ios/project.yml, `entitlements > path`), so both
    apps carry a tracked entitlements file; `just ios-template-check` guards the
    wiring. Deliberately empty: the console requests no special capabilities —
    in particular NO iCloud (that entitlement belongs only to the wallet's blob
    backup; the console's Secure-Enclave key and keychain items need none).
  -->
</dict>
</plist>
