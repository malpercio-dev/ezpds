{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Obsign",
  "version": "0.1.1",
  "identifier": "dev.malpercio.identitywallet",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Obsign",
        "width": 400,
        "height": 600,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "iOS": {
      "frameworks": ["SystemConfiguration", "AuthenticationServices"],
      "bundleVersion": "2",
      "template": "../../scripts/ios/project.yml"
    }
  }
}
