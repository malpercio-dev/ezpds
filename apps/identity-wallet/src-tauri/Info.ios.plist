<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Tauri merges this into the generated iOS Info.plist on every build (local + CI), so
    App Store Connect's "Missing Compliance" gate is answered automatically and no one has
    to click through the encryption dialog per build.

    ITSAppUsesNonExemptEncryption = false  =>  the app's encryption is EXEMPT from US export
    licensing. Obsign uses only standard, *published* algorithms (TLS via rustls, AES-256-GCM,
    P-256/ECDSA) for its own security, which qualifies for the standard/mass-market exemption.

    This is a LEGAL self-declaration. If an export-compliance review concludes otherwise, set
    this to <true/> and supply export documentation in App Store Connect.
    https://developer.apple.com/documentation/bundleresources/information-property-list/itsappusesnonexemptencryption
  -->
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>

  <!--
    Register the OAuth callback URL scheme(s). The primary scheme is
    org.obsign.identitywallet: — the wallet's canonical OAuth client_id host
    (identitywallet.obsign.org) in reverse order, the pairing the atproto OAuth spec
    requires for a native client's private-use redirect URI (third-party authorization
    servers like bsky.social enforce it). It must match the REDIRECT_URI/CALLBACK_SCHEME
    constants in src-tauri/src/pds_client.rs and the redirect_uris in the Custos-served
    client metadata (V042-seeded row). The scheme is consumed by
    ASWebAuthenticationSession's callbackURLScheme (the vendored
    tauri-plugin-auth-session), not by a deep link. The iOS bundle identifier
    (tauri.conf.json `identifier`) deliberately did NOT change with the scheme —
    provisioning/TestFlight are untouched.

    The legacy dev.malpercio.identitywallet entry is kept during the transition so
    wallet builds shipped before the scheme change (whose Custos rows still list the
    old redirect_uri, V013) keep completing their callbacks.
  -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>org.obsign.identitywallet</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>org.obsign.identitywallet</string>
      </array>
    </dict>
    <dict>
      <key>CFBundleURLName</key>
      <string>dev.malpercio.identitywallet</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>dev.malpercio.identitywallet</string>
      </array>
    </dict>
  </array>

  <!--
    Face ID gates the migration PLC-op submission (the DID-repointing operation the wallet
    signs locally) so a momentary unlock can't authorize an identity change. Touch ID /
    device passcode are used on devices without Face ID. Tauri merges this key into the
    generated iOS Info.plist, satisfying iOS's NSFaceIDUsageDescription requirement for the
    biometric plugin.
  -->
  <key>NSFaceIDUsageDescription</key>
  <string>Confirm it's you before authorizing the identity change to migrate your account.</string>

  <!--
    The camera is used only to scan the QR code an app's sign-in page shows, so you can approve
    a cross-device login from your phone without typing the code. Tauri merges this key into the
    generated iOS Info.plist, satisfying iOS's NSCameraUsageDescription requirement for the
    barcode-scanner plugin (the wallet-confirmed OAuth consent scan path).
  -->
  <key>NSCameraUsageDescription</key>
  <string>Scan the QR code on an app's sign-in page to approve signing in with your device key.</string>

  <!--
    Make the iCloud Drive ubiquity container (the user-held blob backup mirror,
    src-tauri/src/blob_backup.rs) visible in the Files app — user-legible sovereignty:
    the mirror is the user's copy, browsable as ordinary files. The container id must
    match Entitlements.ios.plist's ubiquity-container-identifiers entry. Apple only
    surfaces the folder after the container first receives a document; the name shown
    is NSUbiquitousContainerName.
  -->
  <key>NSUbiquitousContainers</key>
  <dict>
    <key>iCloud.dev.malpercio.identitywallet</key>
    <dict>
      <key>NSUbiquitousContainerIsDocumentScopePublic</key>
      <true/>
      <key>NSUbiquitousContainerName</key>
      <string>Obsign</string>
      <key>NSUbiquitousContainerSupportedFolderLevels</key>
      <string>Any</string>
    </dict>
  </dict>

  <!--
    Background media-backup scheduling (src-tauri/src/bg_backup.rs). The `processing`
    background mode lets the app register a BGProcessingTask, and every identifier the app
    submits to BGTaskScheduler must be pre-declared in BGTaskSchedulerPermittedIdentifiers
    or iOS refuses to register/submit it. The identifier string MUST stay in sync with
    bg_backup::BACKUP_TASK_IDENTIFIER (bundle-id-prefixed by Apple convention). On fire the
    task runs an incremental, CID-verified backup pass for each opted-in identity, so a
    mirror stays topped up without the user opening the app.
  -->
  <key>UIBackgroundModes</key>
  <array>
    <string>processing</string>
  </array>
  <key>BGTaskSchedulerPermittedIdentifiers</key>
  <array>
    <string>dev.malpercio.identitywallet.blob-backup</string>
  </array>
</dict>
</plist>
